rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isValidNewReservation() {
      let data = request.resource.data;
      return request.auth != null
        && data.ownerId == request.auth.uid
        && data.teacherName is string
        && data.room is string
        && data.date is string
        && data.startTime is string
        && data.endTime is string
        && data.status is string
        && (data.room == '미래창작공방' || data.room == '에듀테크 교육실')
        && data.status == 'active'
        && data.date.matches('^[0-9]{4}-[0-9]{2}-[0-9]{2}$')
        && data.startTime.matches('^([0-1][0-9]|2[0-3]):[0-5][0-9]$')
        && data.endTime.matches('^([0-1][0-9]|2[0-3]):[0-5][0-9]$');
    }

    function isValidCancelUpdate() {
      let before = resource.data;
      let after = request.resource.data;
      return before.status == 'active'
        && after.status == 'canceled'
        && after.diff(before).affectedKeys().hasOnly(['status']);
    }

    match /reservations/{reservationId} {
      allow read: if true;

      allow create: if isValidNewReservation();

      allow update: if isValidCancelUpdate();

      // 임시 조치: 로그인이 없어 누구나 취소 가능한 상태
      allow delete: if true;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
